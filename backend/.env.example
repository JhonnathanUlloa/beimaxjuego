# Configuración del Backend Beimax

# Puerto del servidor
PORT=3000

# Clave secreta para JWT (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Configuración de base de datos
DB_PATH=./beimax.db

# Entorno
NODE_ENV=development

# ========== AI Provider ==========
# auto: usa OpenRouter si existe API key, si no LM Studio
# openrouter: fuerza OpenRouter
# lmstudio: fuerza LM Studio local
AI_PROVIDER=auto

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_URL=https://openrouter.ai/api/v1
# Modelo free recomendado para concurso (cámbialo si deja de estar disponible)
OPENROUTER_MODEL=google/gemma-3-4b-it:free
OPENROUTER_FALLBACK_MODEL=google/gemma-4-26b-a4b-it:free
# Cadena de modelos gratis para fallback automático (orden de prioridad)
OPENROUTER_MODEL_CANDIDATES=google/gemma-3-4b-it:free,google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free,google/gemma-3-12b-it:free,nvidia/nemotron-nano-9b-v2:free
# Headers opcionales de atribución
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=BeiMax

# LM Studio (fallback/local)
LM_STUDIO_URL=http://localhost:1234
